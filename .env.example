# ── 복사해서 .env 로 사용 (.env는 git ignore) ──────────────────────────
DB_PASSWORD=change-me

# AI 코치 (필수 — 없으면 COACH_MOCK=1로 모의 응답)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
COACH_MOCK=

# 배포 시 0 → 데모 주간 계획 시드 끄기(프로필·목표·시간표만 시드, 첫 화면은 온보딩)
# 로컬 개발은 비워두면 데모 주간 계획이 자동 생성됨
SEED_DEMO_WEEK=

# Cloudflare Tunnel 토큰 (Zero Trust 대시보드에서 named tunnel 생성 후 발급)
# 프로덕션(docker-compose.prod.yml)의 cloudflared 컨테이너가 사용
TUNNEL_TOKEN=

# Strava 연동 (https://www.strava.com/settings/api 에서 앱 등록 후 발급)
# Authorization Callback Domain에 API 도메인(localhost 또는 배포 도메인)을 등록할 것
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# OAuth 콜백 후 돌아갈 프론트 주소 / API 외부 주소
WEB_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000

TZ=Asia/Seoul
